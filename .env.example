# OpenAI (required for quiz generation)
OPENAI_API_KEY=
# Optional override; defaults in code if unset
# OPENAI_MODEL=gpt-5.2

# Upstash Redis — enables short "Copy link" URLs (/quiz?sid=…)
# Create a database at https://console.upstash.com/ → REST API → copy URL and token
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# PostgreSQL (Neon, etc.) — required for sign-in and saved quizzes
DATABASE_URL=

# Auth.js — required for /api/auth and magic links
# Generate with: openssl rand -base64 32
AUTH_SECRET=
# Public URL of the app (no trailing slash); used for magic-link redirects
AUTH_URL=http://localhost:3000

# Optional: canonical site URL for OG/sitemap/embeds (overrides AUTH_URL for getSiteUrl if set)
# NEXT_PUBLIC_SITE_URL=https://example.com

# Resend — magic-link email (https://resend.com)
RESEND_API_KEY=
AUTH_EMAIL_FROM="QuizForge <onboarding@resend.dev>"
